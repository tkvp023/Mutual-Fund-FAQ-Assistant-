# ============================================
# RAG-based Mutual Fund FAQ Chatbot
# Environment Variables
# ============================================

# Groq API Key (required) — Get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model Configuration
GROQ_MODEL=llama-3.1-8b-instant
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Pipeline Settings
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K=5
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=800

# ── Deployment (Railway) ────────────────────
# Comma-separated list of allowed frontend origins (CORS)
# ALLOWED_ORIGINS=https://your-app.vercel.app

# ChromaDB persist directory (use Railway volume mount path in production)
# CHROMA_PERSIST_DIR=/data/chroma_db

